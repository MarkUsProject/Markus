default: &default
  adapter: postgresql
  encoding: unicode
  host: <%= ENV['PGHOST'] %>
  username: <%= ENV['PGUSER'] %>
  password: <%= ENV['PGPASSWORD'] %>
  pool: 5
  database: <%= ENV['PGDATABASE'] %>
  port: <%= ENV['PGPORT'] %>

development:
  <<: *default

test:
  <<: *default
  database: <%= "#{ENV.fetch('PGDATABASETEST') { ENV.fetch('PGDATABASE', '') + '-test' }}#{ENV['TEST_ENV_NUMBER']}" %>

production:
  <<: *default
