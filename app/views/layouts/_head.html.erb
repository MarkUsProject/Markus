<meta charset='UTF-8'>
<meta http-equiv='X-UA-Compatible' content='IE=Edge'>
<meta name='viewport' content='width=device-width, initial-scale=1'>
<%= action_cable_meta_tag %>
<%= csrf_meta_tags %>
<%= csp_meta_tag %>
<!-- The following meta tag is used by the styled-components dependency.
     See https://styled-components.com/docs/advanced#security -->
<meta property="csp-nonce" content="<%= content_security_policy_nonce %>">
<%= stylesheet_link_tag 'application' %>
<%= stylesheet_link_tag 'application_webpack' %>
<% if @current_user&.theme == 'dark' %>
  <%= stylesheet_link_tag 'dark_theme' %>
  <%= favicon_link_tag 'favicon_dark.svg' %>
<% else %>
  <%= stylesheet_link_tag 'light_theme' %>
  <%= favicon_link_tag 'favicon.ico' %>
<% end %>
<%= javascript_tag("const AUTH_TOKEN = document.querySelector('[name=\"csrf-token\"]').content;", nonce: true) if protect_against_forgery? %>
<%= javascript_tag nonce: true do %>
  const DOCS_URL = '<%= Settings.docs_url %>';
  const I18N_LOCALE = '<%= I18n.locale %>';
<% end %>
